# --- AI providers ---
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# --- Twilio (WhatsApp) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=+12177344591 # Twilio sandbox number, or your approved WA number

# --- Laptop agent auth ---
# Any random string. Must match AGENT_SHARED_SECRET in laptop-agent/.env
AGENT_SHARED_SECRET=change_me_to_something_random

# --- Server ---
PORT=3000

# Optional: comma-separated list of phone numbers (E.164, no "whatsapp:" prefix)
# allowed to use this system. Leave blank to allow anyone who messages the number
# (NOT recommended once this is public).
ALLOWED_NUMBERS=+919113630013
